{
	"[dockercompose]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.autoIndent": "advanced",
		"editor.quickSuggestions": {
			"other": true,
			"comments": false,
			"strings": true
		},
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[go]": {
		"editor.formatOnPaste": false,
		"editor.formatOnSave": false,
		"editor.formatOnType": false,
		"editor.defaultFormatter": "golang.go"
	},
	"[html]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[javascript]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[lua]": {
		"editor.formatOnSave": false,
		"editor.insertSpaces": false,
		"editor.tabSize": 2,
		"editor.defaultFormatter": "JohnnyMorganz.stylua"
	},
	"[markdown]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[python]": {
		"editor.codeActionsOnSave": {
			"source.organizeImports": "always"
		},
		"editor.defaultFormatter": "eeyore.yapf",
		"editor.detectIndentation": false,
		"editor.formatOnPaste": false,
		"editor.formatOnSave": true,
		"editor.formatOnSaveMode": "modifications",
		"editor.formatOnType": true,
		"editor.indentSize": "tabSize",
		"editor.insertSpaces": false,
		"editor.tabSize": 2
	},
	"[shellscript]": {
		"editor.defaultFormatter": "mkhl.shfmt"
	},
	"[terraform]": {
		"editor.defaultFormatter": "hashicorp.terraform",
		"editor.formatOnSave": true
	},
	"[yaml]": {
		"editor.defaultFormatter": "redhat.vscode-yaml",
		"editor.insertSpaces": true,
		"editor.tabSize": 2
	},
	"azureTerraform.survey": {
		"surveyPromptDate": "never",
		"surveyPromptIgnoredCount": 0
	},
	"editor.rulers": [
		80,
		100,
		120,
		140,
		160
	],
	"editor.semanticTokenColorCustomizations": {
		"enabled": true,
		"rules": {
			"string": {
				"fontStyle": "italic"
			}
		}
	},
	"editor.tokenColorCustomizations": {
		"textMateRules": [
			{
				"scope": [
					"string",
					"string.quoted",
					"string.template"
				],
				"settings": {
					"fontStyle": "italic"
				}
			}
		]
	},
	"extension-uninstaller.uninstall": [
		"ms-vscode.azure-repos",
		"ms-kubernetes-tools.vscode-kubernetes-tools"
	],
	"files.associations": {
		".boto": "toml",
		".style.yapf": "toml",
		"*.env": "properties",
		"*.jobs": "shellscript",
		"*.kdl": "go",
		"*.sh": "shellscript",
		"*.zsh": "shellscript",
		"**/functions/*": "shellscript",
		"**/init.d/*": "shellscript",
		"**/install.d/*": "shellscript",
		"**/pylintrc": "toml",
		"aliases": "shellscript",
		"Caddyfile.orig": "nginx",
		"Caddyfile": "nginx",
		"envs": "shellscript",
		"install": "shellscript",
		"secrets": "shellscript",
		"setopt": "shellscript",
		"setup": "shellscript",
		"start": "shellscript",
		"*.plugins": "ruby",
		"*.tf": "terraform"
	},
	"files.exclude": {
		"**/__pycache__": true,
		"**/.dropbox.cache": true,
		"**/.DS_Store": true,
		"**/.git": true,
		"**/.hg": true,
		"**/.svn": true,
		"**/.venv": true,
		"**/.zsh_history": true,
		"**/Thumbs.db": true,
		"**/vendor": true,
		"**/venv": true
	},
	"isort.args": [
		"--settings-path",
		"${workspaceFolder}/pyproject.toml"
	],
	"isort.path": [
		"${env:HOME}/.pyenv/shims/isort"
	],
	"markdownlint.config": {
		"MD004": false,
		"MD005": false,
		"MD006": false,
		"MD007": false,
		"MD029": false,
		"MD030": false,
		"MD032": false
	},
	"markdownlint.lintWorkspaceGlobs": [
		"**/*.{md,mkd,mdwn,mdown,markdown,markdn,mdtxt,mdtext,workbook}",
		"!**/*.code-search",
		"!**/bower_components",
		"!**/node_modules",
		"!**/.git",
		"!**/vendor",
		"!**/.v1/**"
	],
	"python.analysis.diagnosticSeverityOverrides": {
		"reportMissingTypeArgument": "none",
		"reportMissingParameterType": "none",
		"reportUnknownArgumentType": "none",
		"reportUnknownLambdaType": "none",
		"reportUnknownMemberType": "none",
		"reportUnknownParameterType": "none",
		"reportUnknownVariableType": "none"
	},
	"python.analysis.exclude": [
		"**/node_modules",
		"**/__pycache__",
		"**/.*",
		"venv"
	],
	"python.analysis.fixAll": [
		"source.unusedImports"
	],
	"remote.SSH.remotePlatform": {
		"192.168.0.20": "linux",
		"192.168.0.21": "linux",
		"adc-nb-01": "linux",
		"adc-srv-01": "linux",
		"localhost": "linux",
		"be-dt-01": "linux",
		"192.168.0.13": "macOS",
		"be-nb-01": "macOS",
		"192.168.1.100": "linux"
	},
	"search.exclude": {
		"**/__pycache__": true,
		"**/.cache": true,
		"**/.dropbox.cache": true,
		"**/*.code-search": true,
		"**/bower_components": true,
		"**/home/.ethereum": true,
		"**/node_modules": true,
		"**/sync/data/**": true
	},
	"security.allowedUNCHosts": [
		"wsl.localhost"
	],
	"settingsSync.ignoredExtensions": [
		"ms-vscode.azure-repos",
		"ms-kubernetes-tools.vscode-kubernetes-tools"
	],
	"settingsSync.ignoredSettings": [
		"-window.zoomLevel",
		"editor.fontSize",
		"terminal.integrated.fontSize",
		"terminal.integrated.lineHeight",
		"editor.lineHeight"
	],
	"terminal.integrated.env.linux": {
		"PYENV_ROOT": "${env:HOME}/.pyenv",
		"PATH": "${env:HOME}/.pyenv/shims:${env:HOME}/.pyenv/bin:${env:PATH}"
	},
	"terminal.integrated.env.osx": {
		"PYENV_ROOT": "${env:HOME}/.pyenv",
		"PATH": "${env:HOME}/.pyenv/shims:${env:HOME}/.pyenv/bin:${env:PATH}"
	},
	"todo-tree.general.tags": [
		"[ ]",
		"[x]",
		"BUG",
		"FIXME",
		"HACK",
		"INFO",
		"NOTE",
		"TODO",
		"XXX"
	],
	"yapf.path": [
		"venv/bin/yapf",
		"${env:HOME}/.pyenv/shims/yapf"
	],
	"workbench.colorCustomizations": {
		"list.activeSelectionBackground": "#33467c",
		"list.activeSelectionForeground": "#c0caf5",
		"list.inactiveSelectionBackground": "#283457",
		"list.inactiveSelectionForeground": "#a9b1d6",
		"list.focusBackground": "#7aa2f766",
		"list.focusForeground": "#c0caf5"
	},
	"application.shellEnvironmentResolutionTimeout": 60,
	"chat.agent.enabled": false,
	"chat.checkpoints.enabled": false,
	"chat.commandCenter.enabled": false,
	"chat.detectParticipant.enabled": false,
	"chat.emptyChatState.enabled": false,
	"chat.extensionTools.enabled": false,
	"chat.extensionUnification.enabled": false,
	"chat.fontSize": 16,
	"chat.implicitContext.suggestedContext": false,
	"chat.math.enabled": false,
	"chat.mcp.autostart": "never",
	"chat.tools.terminal.enableAutoApprove": false,
	"chat.tools.todos.showWidget": false,
	"chat.undoRequests.restoreInput": false,
	"chat.useAgentsMdFile": false,
	"chat.useFileStorage": false,
	"chat.viewSessions.enabled": false,
	"chat.viewTitle.enabled": false,
	"chat.viewWelcome.enabled": false,
	"chatgpt.openOnStartup": false,
	"chatgpt.runCodexInWindowsSubsystemForLinux": true,
	"diffEditor.ignoreTrimWhitespace": false,
	"diffEditor.maxComputationTime": 0,
	"diffEditor.useInlineViewWhenSpaceIsLimited": false,
	"docker.extension.enableComposeLanguageServer": false,
	"editor.autoClosingBrackets": "never",
	"editor.autoClosingQuotes": "never",
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.detectIndentation": false,
	"editor.detectIndentation": false,
	"editor.fontFamily": "'Agave Nerd Font', 'CaskaydiaMono Nerd Font', 'NovaMono Nerd Font', Consolas, monospace, 'Symbols Nerd Font', 'Symbols Nerd Font Mono'",
	"editor.fontLigatures": true,
	"editor.fontSize": 14,
	"editor.formatOnSave": true,
	"editor.formatOnSaveMode": "file",
	"editor.indentSize": "tabSize",
	"editor.insertSpaces": false,
	"editor.insertSpaces": false,
	"editor.lineHeight": 1.8,
	"editor.maxTokenizationLineLength": 50000,
	"editor.minimap.enabled": false,
	"editor.mouseWheelZoom": true,
	"editor.tabSize": 2,
	"editor.tabSize": 2,
	"editor.wordWrap": "on",
	"evenBetterToml.schema.enabled": true,
	"explorer.autoReveal": true,
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"extensions.ignoreRecommendations": true,
	"extensions.supportNodeGlobalNavigator": true,
	"files.autoSave": "afterDelay",
	"files.autoSaveDelay": 1250,
	"files.eol": "\n",
	"files.trimTrailingWhitespace": true,
	"files.trimTrailingWhitespace": true,
	"geminicodeassist.displayInlineContextHint": false,
	"geminicodeassist.enableTelemetry": false,
	"geminicodeassist.inlineSuggestions.enableAuto": false,
	"geminicodeassist.project": "stellar-operand-420618",
	"git.autofetch": true,
	"git.confirmSync": false,
	"git.enabled": true,
	"git.enableSmartCommit": true,
	"git.followTagsWhenSync": true,
	"git.ignoreLimitWarning": true,
	"git.ignoreMissingGitWarning": true,
	"git.openRepositoryInParentFolders": "always",
	"git.postCommitCommand": "sync",
	"git.rebaseWhenSync": true,
	"github.copilot.editor.enableAutoCompletions": false,
	"github.copilot.editor.enableCodeActions": false,
	"github.copilot.nextEditSuggestions.enabled": false,
	"github.copilot.renameSuggestions.triggerAutomatically": false,
	"go.inlayHints.constantValues": true,
	"go.inlayHints.ignoredError": true,
	"go.inlayHints.parameterNames": true,
	"go.installDependenciesWhenBuilding": true,
	"go.showWelcome": false,
	"go.testExplorer.showDynamicSubtestsInEditor": true,
	"go.toolsManagement.autoUpdate": true,
	"gremlins.showInProblemPane": true,
	"grunt.autoDetect": "off",
	"gulp.autoDetect": "off",
	"isort.importStrategy": "fromEnvironment",
	"jake.autoDetect": "off",
	"json.schemaDownload.enable": true,
	"json.validate.enable": false,
	"makefile.configureOnOpen": false,
	"notebook.experimental.generate": false,
	"npm.autoDetect": "off",
	"prettier.useEditorConfig": true,
	"python.analysis.autoIndent": false,
	"python.analysis.typeEvaluation.strictDictionaryInference": true,
	"python.analysis.typeEvaluation.strictListInference": true,
	"python.analysis.typeEvaluation.strictSetInference": true,
	"python.createEnvironment.trigger": "off",
	"python.defaultInterpreterPath": "${env:HOME}/.pyenv/shims/python",
	"python.REPL.enableREPLSmartSend": false,
	"python.terminal.activateEnvironment": false,
	"redhat.telemetry.enabled": false,
	"remote.autoForwardPortsSource": "hybrid",
	"remote.SSH.experimental.chat": false,
	"remote.tunnels.access.hostNameOverride": "be-nb-01",
	"remote.tunnels.access.preventSleep": true,
	"rewrap.reformat": true,
	"scm.repositories.selectionMode": "single",
	"security.workspace.trust.untrustedFiles": "open",
	"terminal.integrated.allowMnemonics": true,
	"terminal.integrated.defaultProfile.linux": "zsh",
	"terminal.integrated.fontSize": 17,
	"terminal.integrated.lineHeight": 1.2,
	"terminal.integrated.mouseWheelZoom": true,
	"typescript.tsc.autoDetect": "off",
	"vsicons.dontShowNewVersionMessage": true,
	"window.confirmSaveUntitledWorkspace": false,
	"window.menuBarVisibility": "classic",
	"window.systemColorTheme": "dark",
	"workbench.editor.labelFormat": "short",
	"workbench.editorLargeFileConfirmation": 50,
	"workbench.experimental.share.enabled": true,
	"workbench.iconTheme": "developer-icon-theme",
	"workbench.panel.showLabels": false,
	"workbench.secondarySideBar.defaultVisibility": "hidden",
	"workbench.secondarySideBar.showLabels": false,
	"yaml.schemaStore.enable": true,
	"yapf.importStrategy": "fromEnvironment",
	"yapf.showDebugLog": true,
	"workbench.productIconTheme": "developer-icons",
	"editor.aiStats.enabled": false,
	"[go.mod]": {
		"editor.defaultFormatter": "golang.go"
	},
	"workbench.colorTheme": "Developers Theme - Firefox Dark",
	"cloudcode.project": "stellar-operand-420618",
	"diffEditor.codeLens": true,
	"workbench.editor.tabSizingFixedMaxWidth": 38,
	"workbench.editor.tabSizingFixedMinWidth": 38,
	"workbench.activityBar.compact": true,
	"notebook.compactView": false,
	"chat.mcp.gallery.enabled": true,
	"window.newWindowProfile": "Default"
}
