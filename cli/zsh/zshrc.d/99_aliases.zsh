alias ack='ag && ag || ack'
alias brew-upgrade='brew update --quiet && brew upgrade --quiet --greedy'
alias code-database='code --profile database'                                          # v2
alias code-devop='code --profile devop'                                                # v2
alias code-golang='code --profile golang'                                              # v2
alias code-python='code --profile python'                                              # v2
alias code-server='$HOME/bin/code serve-web --accept-server-license-terms --port 8000' # v2
alias dc='docker ps -a --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"'
alias dcla='llog error "this alias changes to just \"dc\"" && dc'
alias dclsa='docker container ls -a --format "table {{.Names}}\t{{.State}}\t{{.RunningFor}}\t{{.Ports}}" | tail -n+2 | sort'
alias dclsa='llog error "this alias changes to just \"dc\"" && dc'
alias di='docker images'
alias dim='docker images -a'
alias docker-engine-start='open --hide --background -a Docker && while ! docker info > /dev/null 2>&1; do sleep 1; done'
alias docker-watch='watch -d -c -n 1 -x docker ps --all --format "table {{.Names}}\t{{.State}}\t{{.RunningFor}}\t{{.Ports}}"'
alias errors='journalctl -b -p err | less'
alias frm='/bin/rm -rf' # v2
alias gb='git branch'
alias gbd='git branch -D'
alias gbr='git branch --remote'
alias gc='git commit --verbose -S'
alias gco='git checkout'
alias gfp='git fetch --all --prune'
alias gfp='git fetch --prune'
alias ggpull='git pull origin'
alias ggpush='git push origin'
alias ggsync='gfp ; git stash --all ; ggpull ; ggpush ; git stash pop'
alias go-fix='goimports -w ./.. ; go mod tidy'
alias go-test='go-fix ; go clean -testcache ; go test ./...'
alias gsl='git stash list'
alias gst='git status --branch --show-stash --untracked-files=all --ignore-submodules=untracked --column=always --renames --find-renames=70%'
alias la='eza -lah --icons --color=auto --group-directories-first' # v2
alias ll='llog error "this alias changes to just \"la\"" && la'
alias lsa='llog error "this alias changes to just \"la\"" && la'
alias new-guid='uuidgen | tr "[A-Z]" "[a-z]"'
alias path='echo -e ${PATH//:/\\n}'
alias ports='sudo lsof -i -P -n | grep LISTEN'
alias s='screen'
alias sl='screen -list'
alias sr='screen -r'
alias tfa='reset ; terraform apply'
alias tfp-summary='tfp-to-bin ; tf-summarize tfplan.binary'
alias tfp-to-bin='tfp -lock=false -out=tfplan.binary >/dev/null'
alias tfp='reset ; terraform plan'
alias tfv='terraform validate'
alias ubuntu-version='lsb_release -a'
alias update-pip='/usr/bin/python3 -m pip install -U pip --upgrade --user'
alias upgrade='sudo apt update --fix-missing --yes ; sudo apt upgrade --yes --no-install-recommends --no-install-suggests ; sudo apt autoremove --purge --yes'
